{
  "name": "astra-stt",
  "version": "0.1.0",
  "description": "Independent speech-to-text service (Groq Whisper). Usable as a module, CLI, or HTTP endpoint.",
  "type": "module",
  "main": "transcribe.js",
  "scripts": {
    "serve": "node --env-file-if-exists=.env server.js",
    "cli": "node --env-file-if-exists=.env cli.js",
    "report": "node --env-file-if-exists=.env report-cli.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "wavefile": "^11.0.0"
  }
}
