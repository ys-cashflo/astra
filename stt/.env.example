# Pick ONE provider and set its key. Options: groq | deepgram | openai | sarvam | local
# Default recommended for multilingual (Indian languages, auto-detect): groq + whisper-large-v3
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3

# Groq (hosted Whisper) — broad multilingual incl. Hindi/Marathi/Tamil/Telugu/Bengali, auto-detect.
# Get key: https://console.groq.com
GROQ_API_KEY=

# Deepgram — fast, but limited Indian-language coverage (mainly English/Hindi).
# Get key: https://console.deepgram.com
# DEEPGRAM_API_KEY=

# OpenAI (whisper-1 / gpt-4o-mini-transcribe)
# OPENAI_API_KEY=

# Sarvam — strongest for Indian languages / dialects (Maithili, Bhojpuri, code-mixed).
# Get key: https://dashboard.sarvam.ai
# SARVAM_API_KEY=
